COMPOSE_PROJECT_NAME=dfs
# Kopiera till .env och fyll i riktiga värden.
# Lösenord hanteras i Docker Secrets (secrets/*.txt) – se README.
POSTGRES_USER=dfs
POSTGRES_DB=dfs

# DATABASE_URL behövs bara utan Docker Secrets (t.ex. lokal utveckling).
# Med Docker Secrets byggs URL:en automatiskt från POSTGRES_* + secrets/db_password.txt.
# DATABASE_URL=postgresql://dfs:<starkt-lösenord>@db:5432/dfs

# Sätt till false för lokal utveckling utan HTTPS
SESSION_COOKIE_SECURE=true

# Antal reverse proxies framför appen (t.ex. 1 för nginx).
# Krävs för korrekt IP-loggning bakom proxy (X-Forwarded-For).
# PROXY_COUNT=1

# Maximal körtid i ms för databasfrågor (PostgreSQL statement_timeout). 0 = ingen gräns.
# DB_QUERY_TIMEOUT_MS=5000

# Maximal filstorlek i MB per uppladdad handling (standard: 20).
# MAX_FIL_STORLEK_MB=20

# ── AI-registrator + mail-worker ──────────────────────────────────────────────

# LLM-backend: "ollama" (lokal) eller "openrouter" (moln).
# Sätt till "ollama" och starta med:  docker compose --profile local-llm up -d
# Sätt till "openrouter" och starta med: docker compose up -d
AI_BACKEND=ollama

# ── Lokal backend (Ollama) ────────────────────────────────────────────────────
# Kräver profilen "local-llm": docker compose --profile local-llm up -d
# Modellen laddas ner automatiskt vid första start.
OLLAMA_MODEL=llama3.2:1b

# ── Molnbackend (OpenRouter) ──────────────────────────────────────────────────
# API-nyckel lagras i secrets/openrouter_api_key.txt (kopiera från .example).
# Se tillgängliga modeller på https://openrouter.ai/models
# Välj en modell med stöd för tool calling (function calling).
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct

# IMAP-inställningar för inkorgen som mail-worker övervakar
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=diarium@example.com
IMAP_FOLDER=INBOX

# SMTP-inställningar för att skicka bekräftelsemejl
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=diarium@example.com
SMTP_FROM=diarium@example.com

# Pollintervall i sekunder (standard: 60)
POLL_INTERVAL_SECONDS=60

# Tidsgräns i minuter för en AI-registrator-session (standard: 5)
# SESSION_TIMEOUT_MINUTES=5
